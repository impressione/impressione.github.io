---
import SiteLayout from "../../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Contato enviado | impressione.me"
  description="Recebemos seu contato e seguimos por e-mail em seguida."
  path="/contato/obrigado"
>
  <main>
    <section class="inner-hero">
      <div class="container contact-hero">
        <div class="feature-card contact-form-card contact-form-hero">
          <div class="section-heading compact form-heading">
            <p class="kicker">Contato enviado</p>
            <h1>Recebemos sua mensagem.</h1>
            <p>
              Nosso time foi notificado e continua a conversa por e-mail em seguida.
            </p>
          </div>

          <div class="form-actions">
            <a href="/" class="button button-secondary">Voltar para a home</a>
            <a href="/contato" class="button button-primary">Enviar outro contato</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
