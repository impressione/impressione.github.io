---
import SiteLayout from "../layouts/SiteLayout.astro";

const services = [
  {
    title: "Produto e arquitetura",
    description:
      "Desenhamos sistemas com foco em clareza de negócio, arquitetura sustentável e evolução real do produto.",
  },
  {
    title: "Desenvolvimento full cycle",
    description:
      "Construímos frontend, backend, integrações e automações com stack moderna e padrões de engenharia consistentes.",
  },
  {
    title: "Qualidade e release",
    description:
      "Estruturamos testes, pipelines, observabilidade e processos de deploy para reduzir risco e acelerar entrega.",
  },
];

const stages = [
  "Descoberta técnica e definição do escopo",
  "Arquitetura, design de solução e priorização",
  "Desenvolvimento com testes e revisão contínua",
  "Build, entrega, hospedagem e monitoramento",
];

const stack = [
  "Aplicações web modernas",
  "APIs e integrações",
  "CI/CD e automação de deploy",
  "Infraestrutura em nuvem",
  "Observabilidade e operação",
  "Testes automatizados e qualidade",
];
---

<SiteLayout
  title="impressione.me | Desenvolvimento de software ponta a ponta"
  description="Software sob medida com desenvolvimento ponta a ponta, testes, build, hospedagem e operação em uma esteira moderna com DevOps."
  path="/"
>
  <main>
    <section class="hero-section">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="kicker">Software, produto e operação em sintonia</p>
          <h1>Desenvolvimento de software do conceito ao ambiente de produção.</h1>
          <p class="lead">
            A impressione.me atua em toda a esteira: estratégia, arquitetura,
            desenvolvimento, testes, build, hospedagem e evolução contínua com práticas modernas de DevOps.
          </p>

          <div class="hero-actions">
            <a href="/contato" class="button button-primary">Falar com a equipe</a>
            <a href="#servicos" class="button button-secondary">Conhecer a esteira</a>
          </div>
        </div>

        <div class="hero-panel" aria-label="Resumo da atuação da impressione.me">
          <div class="hero-card hero-card-large">
            <p class="card-label">Atuação ponta a ponta</p>
            <p class="card-value">Planejar, construir, testar, publicar e operar.</p>
          </div>

          <div class="hero-card-grid">
            <div class="hero-card">
              <p class="card-label">Entrega</p>
              <p class="card-value">Fluxos enxutos com release contínuo.</p>
            </div>
            <div class="hero-card">
              <p class="card-label">Qualidade</p>
              <p class="card-value">Testes e observabilidade desde o início.</p>
            </div>
            <div class="hero-card">
              <p class="card-label">Infra</p>
              <p class="card-value">Deploy, cloud e operação com previsibilidade.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container stat-band">
        <div>
          <p class="stat-value">Produto + Engenharia</p>
          <p class="stat-copy">A solução é pensada para o negócio e implementada com responsabilidade técnica.</p>
        </div>
        <div>
          <p class="stat-value">DevOps na prática</p>
          <p class="stat-copy">Pipelines, build, hospedagem e monitoramento entram como parte da entrega.</p>
        </div>
        <div>
          <p class="stat-value">Escalável desde cedo</p>
          <p class="stat-copy">Estrutura pronta para evoluir com menos retrabalho e mais segurança.</p>
        </div>
      </div>
    </section>

    <section id="servicos" class="section">
      <div class="container">
        <div class="section-heading">
          <p class="kicker">Serviços</p>
          <h2>Uma operação técnica completa para tirar sistemas do papel e sustentar crescimento.</h2>
          <p>
            Trabalhamos lado a lado com empresas que precisam transformar demandas de software em produtos estáveis, úteis e bem operados.
          </p>
        </div>

        <div class="card-grid three-up">
          {services.map((service) => (
            <article class="feature-card">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="esteira" class="section section-accent">
      <div class="container process-grid">
        <div class="section-heading compact">
          <p class="kicker">Esteira de entrega</p>
          <h2>Do planejamento à operação, com menos atrito entre times e etapas.</h2>
          <p>
            Organizamos a jornada técnica para que decisões, código, infraestrutura e qualidade conversem entre si.
          </p>
        </div>

        <ol class="timeline">
          {stages.map((stage, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <p>{stage}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section id="stack" class="section">
      <div class="container stack-grid">
        <div class="section-heading compact">
          <p class="kicker">Stack moderna com DevOps</p>
          <h2>Tecnologia atual, automação e processos confiáveis para entregar com velocidade.</h2>
          <p>
            A stack é escolhida conforme o contexto do projeto, sempre com foco em manutenção, desempenho, rastreabilidade e segurança operacional.
          </p>
        </div>

        <div class="tag-panel">
          {stack.map((item) => (
            <span class="tag">{item}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container cta-panel">
        <div>
          <p class="kicker">Vamos conversar</p>
          <h2>Se você precisa evoluir um produto ou estruturar uma nova entrega, a impressione.me pode assumir a jornada técnica com você.</h2>
        </div>

        <div class="cta-actions">
          <a href="/contato" class="button button-primary">Ir para contato</a>
          <a href="mailto:contato@impressione.me" class="button button-secondary">contato@impressione.me</a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
