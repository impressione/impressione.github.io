---
import SiteLayout from "../layouts/SiteLayout.astro";

const services = [
  {
    title: "Produto, IA e arquitetura",
    description:
      "Desenhamos soluções com foco em clareza de negócio, arquitetura sustentável, uso pragmático de IA e evolução real do produto.",
  },
  {
    title: "Desenvolvimento com agentes autônomos",
    description:
      "Construímos frontend, backend, integrações e fluxos apoiados por agentes autônomos para acelerar entrega, documentação e execução operacional.",
  },
  {
    title: "Qualidade e release",
    description:
      "Estruturamos testes, pipelines, observabilidade e processos de deploy para reduzir risco e colocar automação inteligente na rotina de entrega.",
  },
];

const stages = [
  "Descoberta técnica e definição do escopo",
  "Arquitetura, design de solução e desenho dos fluxos com IA",
  "Desenvolvimento com agentes autônomos, testes e revisão contínua",
  "Build, entrega, hospedagem, monitoramento e evolução operacional",
];

const stack = [
  "Aplicações web modernas",
  "APIs e integrações",
  "IA aplicada ao produto",
  "Agentes autônomos para automação",
  "CI/CD e automação de deploy",
  "Infraestrutura em nuvem",
  "Observabilidade e operação",
  "Testes automatizados e qualidade",
];
---

<SiteLayout
  title="impressione.me | Software, IA e agentes autônomos"
  description="Software sob medida com IA aplicada, agentes autônomos, testes, build, hospedagem e operação em uma esteira moderna com DevOps."
  path="/"
>
  <main>
    <section class="hero-section">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="kicker">Software, IA e operação em sintonia</p>
          <h1>Desenvolvimento de software com IA aplicada e agentes autônomos.</h1>
          <p class="lead">
            A impressione.me atua em toda a esteira: estratégia, arquitetura,
            desenvolvimento, testes, build, hospedagem e evolução contínua com práticas modernas de DevOps, automação e agentes autônomos.
          </p>

          <div class="hero-actions">
            <a href="/contato" class="button button-primary">Falar com a equipe</a>
            <a href="#servicos" class="button button-secondary">Conhecer a esteira</a>
          </div>
        </div>

        <div class="hero-panel" aria-label="Resumo da atuação da impressione.me">
          <div class="hero-card hero-card-large">
            <p class="card-label">Atuação ponta a ponta</p>
            <p class="card-value">Planejar, construir, automatizar, publicar e operar.</p>
          </div>

          <div class="hero-card-grid">
            <div class="hero-card">
              <p class="card-label">IA aplicada</p>
              <p class="card-value">Automação útil para acelerar produto e engenharia.</p>
            </div>
            <div class="hero-card">
              <p class="card-label">Agentes</p>
              <p class="card-value">Fluxos autônomos para execução técnica e operacional.</p>
            </div>
            <div class="hero-card">
              <p class="card-label">Infra</p>
              <p class="card-value">Deploy, cloud e operação com previsibilidade.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container stat-band">
        <div>
          <p class="stat-value">Produto + Engenharia + IA</p>
          <p class="stat-copy">A solução é pensada para o negócio e implementada com IA de forma responsável e útil.</p>
        </div>
        <div>
          <p class="stat-value">Agentes autônomos na prática</p>
          <p class="stat-copy">Automação, execução assistida e fluxos inteligentes entram como parte da entrega.</p>
        </div>
        <div>
          <p class="stat-value">DevOps escalável</p>
          <p class="stat-copy">Pipelines, hospedagem e operação prontos para evoluir com menos retrabalho e mais segurança.</p>
        </div>
      </div>
    </section>

    <section id="servicos" class="section">
      <div class="container">
        <div class="section-heading">
          <p class="kicker">Serviços</p>
          <h2>Uma operação técnica completa para tirar sistemas do papel com software, IA e automação de verdade.</h2>
          <p>
            Trabalhamos lado a lado com empresas que precisam transformar demandas de software em produtos estáveis, úteis, bem operados e potencializados por IA.
          </p>
        </div>

        <div class="card-grid three-up">
          {services.map((service) => (
            <article class="feature-card">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="esteira" class="section section-accent">
      <div class="container process-grid">
        <div class="section-heading compact">
          <p class="kicker">Esteira de entrega</p>
          <h2>Do planejamento à operação, com IA integrada ao processo e menos atrito entre times e etapas.</h2>
          <p>
            Organizamos a jornada técnica para que decisões, código, agentes, infraestrutura e qualidade conversem entre si.
          </p>
        </div>

        <ol class="timeline">
          {stages.map((stage, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <p>{stage}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section id="stack" class="section">
      <div class="container stack-grid">
        <div class="section-heading compact">
          <p class="kicker">Stack moderna com IA e DevOps</p>
          <h2>Tecnologia atual, agentes autônomos, automação e processos confiáveis para entregar com velocidade.</h2>
          <p>
            A stack é escolhida conforme o contexto do projeto, sempre com foco em manutenção, desempenho, rastreabilidade, segurança operacional e uso efetivo de IA.
          </p>
        </div>

        <div class="tag-panel">
          {stack.map((item) => (
            <span class="tag">{item}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container cta-panel">
        <div>
          <p class="kicker">Vamos conversar</p>
          <h2>Se você precisa evoluir um produto com IA ou estruturar uma nova entrega com agentes autônomos, a impressione.me pode assumir essa jornada técnica com você.</h2>
        </div>

        <div class="cta-actions">
          <a href="/contato" class="button button-primary">Ir para contato</a>
          <a href="mailto:contato@impressione.me" class="button button-secondary">contato@impressione.me</a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
